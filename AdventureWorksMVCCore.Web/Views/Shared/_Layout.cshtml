<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewBag.Title - Unicorn Bike Rentals</title>
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" href="/favicon/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon/favicon-16x16.png" sizes="16x16" />
    <link rel="manifest" href="/favicon/manifest.json" />
    <link rel="mask-icon" href="/favicon/safari-pinned-tab.svg" color="#6d28d9" />
    <link href="@Url.Content("~/css/cyclestore.css")" rel="stylesheet" />
</head>
<body>
    <svg width="0" height="0" style="position:absolute" aria-hidden="true">
        <symbol id="bike" viewBox="0 0 64 40"><g fill="none" stroke="currentColor" stroke-width="2.1" stroke-linecap="round" stroke-linejoin="round"><circle cx="13" cy="28" r="10"/><circle cx="51" cy="28" r="10"/><path d="M13 28 L26 28 L38 12 M26 28 L36 28 L51 28 M38 12 L44 12 M36 28 L30 13 L24 13 M51 28 L44 12"/><path d="M22 13 h7"/></g></symbol>
        <symbol id="cog" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3.2"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M19 5l-2 2M7 17l-2 2"/></g></symbol>
        <symbol id="shirt" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="1.9" stroke-linejoin="round" d="M8 3 4 6l2 3 2-1v10h8V8l2 1 2-3-4-3-3 2H11z"/></symbol>
        <symbol id="helmet" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 14a9 8 0 0 1 18 0"/><path d="M3 14h18l-2 3H5z"/><path d="M9 9h7"/></g></symbol>
        <symbol id="search" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="7"/><path d="M20 20l-3.2-3.2"/></g></symbol>
        <symbol id="cart" viewBox="0 0 24 24"><g fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 4h2l2.2 11h9.5l1.8-7H6"/><circle cx="9" cy="19" r="1.4"/><circle cx="17" cy="19" r="1.4"/></g></symbol>
        <symbol id="arrow" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M13 6l6 6-6 6"/></symbol>
        <symbol id="back" viewBox="0 0 24 24"><path fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M11 6l-6 6 6 6"/></symbol>
    </svg>

    <header class="bar">
        <div class="wrap">
            <a class="brand" href="/">
                <span class="mark"><svg><use href="#bike"/></svg></span>
                <span>Unicorn Bike Rentals<small>Core Cycles Store</small></span>
            </a>
            <nav class="cats">
                <a href="/">Home</a>
                <a href="/#cat-bikes">Bikes</a>
                <a href="/#cat-components">Components</a>
                <a href="/#cat-clothing">Clothing</a>
                <a href="/#cat-accessories">Accessories</a>
            </nav>
            <div class="right">
                <label class="search"><svg style="width:16px;height:16px"><use href="#search"/></svg><input placeholder="Search the catalog…" aria-label="Search the catalog" /></label>
                <button class="icobtn" aria-label="Cart"><svg style="width:18px;height:18px"><use href="#cart"/></svg><span class="dot">0</span></button>
            </div>
        </div>
    </header>

    <main>
        @RenderBody()
    </main>

    <footer class="site">
        <div class="wrap">
            <span class="brand">🦄 Unicorn Bike Rentals</span>
            <span>Core Cycles Store · ASP.NET Core MVC · data served live from SQL Server</span>
        </div>
    </footer>
</body>
</html>
