@model AdventureWorksMVCCore.Web.Models.Product
@{
    ViewBag.Title = Model.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var cat = ViewBag.Category as string;
    var sub = ViewBag.Subcategory as string;
    var gallery = ViewBag.Gallery as List<string> ?? new List<string>();
    var mainImg = gallery.FirstOrDefault()
        ?? CatalogImages.For(cat, sub, Model.ProductNumber, Model.ProductId);
    var related = ViewBag.Related as List<AdventureWorksMVCCore.Web.Models.ProductCard>
        ?? new List<AdventureWorksMVCCore.Web.Models.ProductCard>();
    var brand = CatalogContent.Brand(Model.Name);
    var rating = CatalogContent.Rating(Model.ProductNumber);
    var rcount = CatalogContent.ReviewCount(Model.ProductNumber);
    var reviews = CatalogContent.Reviews(Model.ProductNumber);
    var was = CatalogContent.CompareAt(Model.ProductNumber, Model.ListPrice);
    var off = CatalogContent.DiscountPercent(Model.ProductNumber, Model.ListPrice);
    var desc = CatalogContent.Description(Model, sub);
}
@functions {
    static string ColorHex(string c) => (c ?? "").ToLowerInvariant() switch
    {
        "black" => "#1b1722", "silver" => "#c4c8cf", "white" => "#eef0f3",
        "red" => "#c0392b", "blue" => "#3454d1", "yellow" => "#e1b12c",
        "grey" => "#8a8f99", "gray" => "#8a8f99", "multi" => "#8b5cf6",
        _ => "#8b5cf6"
    };
    static string Line(string l) => (l ?? "").Trim().ToUpperInvariant() switch
    {
        "M" => "M — Mountain", "R" => "R — Road", "T" => "T — Touring", "S" => "S — Standard", _ => l
    };
}

<div class="wrap">
    <div class="crumb">
        <a asp-controller="Home" asp-action="Index">Home</a> /
        @if (!string.IsNullOrWhiteSpace(cat))
        {
            <a asp-controller="Products" asp-action="Category" asp-route-id="@cat">@cat</a><text> / </text>
        }
        @if (Model.ProductSubcategoryId.HasValue && !string.IsNullOrWhiteSpace(sub))
        {
            <a asp-controller="Products" asp-action="Subcategory" asp-route-id="@Model.ProductSubcategoryId">@sub</a><text> / </text>
        }
        <b>@Model.Name</b>
    </div>

    <div class="detail">
        <div class="gallery" data-gallery>
            <div class="dvis gmain"><img src="@Url.Content(mainImg)" alt="@Model.Name" /></div>
            @if (gallery.Count > 1)
            {
                <div class="gthumbs">
                    @for (var i = 0; i < gallery.Count; i++)
                    {
                        <button type="button" class="gthumb @(i == 0 ? "on" : "")" data-src="@Url.Content(gallery[i])" aria-label="View @(i + 1)">
                            <img src="@Url.Content(gallery[i])" alt="" />
                        </button>
                    }
                </div>
            }
        </div>
        <div class="dwrap">
            @if (Model.ProductSubcategoryId.HasValue)
            {
                <a class="btn ghost" style="padding:8px 14px;font-size:13px" asp-controller="Products" asp-action="Subcategory" asp-route-id="@Model.ProductSubcategoryId"><svg><use href="#back"/></svg> Back</a>
            }
            @if (!string.IsNullOrWhiteSpace(sub))
            {
                <div style="margin:14px 0 2px"><span class="viewing"><svg><use href="#tag"/></svg> You're viewing · @sub</span></div>
            }
            <h1>@Model.Name</h1>
            <div class="pcode mono">@(brand != null ? brand + " · " : "")@Model.ProductNumber</div>
            <div class="rate rate-lg">
                @await Html.PartialAsync("_Stars", rating)
                <span class="rcount">@rating.ToString("0.0") · @rcount reviews</span>
            </div>
            <div class="dprice">
                <b class="num">$@Model.ListPrice.ToString("N2")</b>
                @if (was > Model.ListPrice)
                {
                    <span class="was num">$@was.ToString("N2")</span>
                    <span class="off">-@off%</span>
                }
            </div>
            <span class="instock">In stock — ships in 24h</span>
            <p class="ddesc">@desc</p>
            <div class="dactions">
                <button class="btn" type="button" data-add-cart="@Model.ProductId">Add to cart <svg><use href="#cart"/></svg></button>
                <a class="btn ghost" asp-controller="Cart" asp-action="Index"><svg><use href="#cart"/></svg> View cart</a>
            </div>

            <div class="specs">
                <span class="eyebrow">Specification</span>
                <dl style="margin:0">
                    <div class="spec"><dt>Product No.</dt><dd class="mono">@Model.ProductNumber</dd></div>
                    @if (!string.IsNullOrWhiteSpace(Model.Color))
                    {
                        <div class="spec"><dt>Color</dt><dd><span class="swatch" style="background:@ColorHex(Model.Color)"></span>@Model.Color</dd></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Size))
                    {
                        <div class="spec"><dt>Size</dt><dd>@Model.Size</dd></div>
                    }
                    @if (Model.Weight.HasValue)
                    {
                        <div class="spec"><dt>Weight</dt><dd class="num">@Model.Weight</dd></div>
                    }
                    <div class="spec"><dt>List price</dt><dd class="num">$@Model.ListPrice.ToString("N2")</dd></div>
                    @if (!string.IsNullOrWhiteSpace(Model.ProductLine))
                    {
                        <div class="spec"><dt>Product line</dt><dd>@Line(Model.ProductLine)</dd></div>
                    }
                    @if (!string.IsNullOrWhiteSpace(Model.Class))
                    {
                        <div class="spec"><dt>Class</dt><dd>@Model.Class</dd></div>
                    }
                    <div class="spec"><dt>Sell start</dt><dd class="num">@Model.SellStartDate.ToString("yyyy-MM-dd")</dd></div>
                </dl>
            </div>
        </div>
    </div>

    <div class="reviews">
        <h2>Ratings &amp; reviews</h2>
        <div class="rev-grid">
            <div class="rev-summary">
                <div class="rev-score num">@rating.ToString("0.0")<span>/5</span></div>
                @await Html.PartialAsync("_Stars", rating)
                <div class="muted">Based on @rcount reviews</div>
            </div>
            <div class="rev-list">
                @foreach (var r in reviews)
                {
                    <div class="rev">
                        <div class="rev-top">
                            <span class="rev-who">@r.Author</span>
                            @await Html.PartialAsync("_Stars", (double)r.Stars)
                        </div>
                        <p>@r.Text</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @if (related.Any())
    {
        <div class="related">
            <h2>More in @sub</h2>
            <div class="prods">
                @foreach (var card in related)
                {
                    @await Html.PartialAsync("_ProductCard", card)
                }
            </div>
        </div>
    }
</div>
