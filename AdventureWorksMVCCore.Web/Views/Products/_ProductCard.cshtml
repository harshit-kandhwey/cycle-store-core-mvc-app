@model AdventureWorksMVCCore.Web.Models.ProductCard
@functions {
    static string ColorHex(string c) => (c ?? "").ToLowerInvariant() switch
    {
        "black" => "#1b1722", "silver" => "#c4c8cf", "white" => "#eef0f3",
        "red" => "#c0392b", "blue" => "#3454d1", "yellow" => "#e1b12c",
        "grey" => "#8a8f99", "gray" => "#8a8f99", "multi" => "#8b5cf6",
        _ => "#8b5cf6"
    };
}
@{ var p = Model.Product; }
<div class="pcard">
    <div class="pvis">
        <a class="pvis-link" asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId" aria-label="@p.Name">
            <img src="@Url.Content(Model.Image)" alt="@p.Name" loading="lazy" />
        </a>
        <button class="qview" type="button" data-qview="@p.ProductId" aria-label="Quick view @p.Name">
            <svg><use href="#zoom"/></svg> Quick view
        </button>
    </div>
    <a class="pbody" asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId">
        <div class="pcode">@p.ProductNumber</div>
        <h3 class="pname">@p.Name</h3>
        <div class="pattrs">
            @if (!string.IsNullOrWhiteSpace(p.Color))
            {
                <span class="attr"><span class="swatch" style="background:@ColorHex(p.Color)"></span>@p.Color</span>
            }
            @if (!string.IsNullOrWhiteSpace(p.Size))
            {
                <span class="attr">Size @p.Size</span>
            }
        </div>
        <div class="prow">
            <div class="price num">$@p.ListPrice.ToString("N2")</div>
            <span class="mini">Details <svg><use href="#arrow"/></svg></span>
        </div>
    </a>
</div>
