@model AdventureWorksMVCCore.Web.Models.SubcategoryProductsViewModel
@{
    ViewBag.Title = Model.Subcategory.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var catName = Model.Subcategory.ProductCategory?.Name;
}
@functions {
    static string ColorHex(string c) => (c ?? "").ToLowerInvariant() switch
    {
        "black" => "#1b1722", "silver" => "#c4c8cf", "white" => "#eef0f3",
        "red" => "#c0392b", "blue" => "#3454d1", "yellow" => "#e1b12c",
        "grey" => "#8a8f99", "gray" => "#8a8f99", "multi" => "#8b5cf6",
        _ => "#8b5cf6"
    };
}

<div class="wrap">
    <div class="crumb">
        <a asp-controller="Home" asp-action="Index">Home</a> /
        <span>@Model.Subcategory.ProductCategory?.Name</span> /
        <b>@Model.Subcategory.Name</b>
    </div>

    <div class="toolbar">
        <h2>@Model.Subcategory.Name <span class="muted">· @Model.Products.Count product@(Model.Products.Count == 1 ? "" : "s")</span></h2>
        <a class="btn ghost" style="padding:9px 16px;font-size:13px" asp-controller="Home" asp-action="Index"><svg><use href="#back"/></svg> All categories</a>
    </div>

    @if (!Model.Products.Any())
    {
        <div class="empty">No products found in this subcategory yet.</div>
    }
    else
    {
        <div class="prods">
            @{ var i = 0; }
            @foreach (var p in Model.Products)
            {
                var img = CatalogImages.For(catName, Model.Subcategory.Name, i);
                i++;
                <a class="pcard" asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId">
                    <div class="pvis"><img src="@Url.Content(img)" alt="@p.Name" loading="lazy" /></div>
                    <div class="pbody">
                        <div class="pcode">@p.ProductNumber</div>
                        <h3 class="pname">@p.Name</h3>
                        <div class="pattrs">
                            @if (!string.IsNullOrWhiteSpace(p.Color))
                            {
                                <span class="attr"><span class="swatch" style="background:@ColorHex(p.Color)"></span>@p.Color</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(p.Size))
                            {
                                <span class="attr">Size @p.Size</span>
                            }
                        </div>
                        <div class="prow">
                            <div class="price num">$@p.ListPrice.ToString("N2")</div>
                            <span class="mini">Details <svg><use href="#arrow"/></svg></span>
                        </div>
                    </div>
                </a>
            }
        </div>
    }
</div>
