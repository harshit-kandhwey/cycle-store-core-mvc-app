@model AdventureWorksMVCCore.Web.Models.SubcategoryProductsViewModel
@{
    ViewBag.Title = Model.Subcategory.Name;
    Layout = "~/Views/Shared/_Layout.cshtml";
    var catName = Model.Subcategory.ProductCategory?.Name;
    var subId = Model.Subcategory.ProductSubcategoryId;
    var curSort = ViewBag.Sort as string;
    var curColor = ViewBag.Color as string;
    var colors = ViewBag.Colors as List<string> ?? new List<string>();
    var sorts = new[] {
        new { v = "name", t = "Name A–Z" },
        new { v = "name-desc", t = "Name Z–A" },
        new { v = "price-asc", t = "Price: low to high" },
        new { v = "price-desc", t = "Price: high to low" },
    };
}
@functions {
    static string ColorHex(string c) => (c ?? "").ToLowerInvariant() switch
    {
        "black" => "#1b1722", "silver" => "#c4c8cf", "white" => "#eef0f3",
        "red" => "#c0392b", "blue" => "#3454d1", "yellow" => "#e1b12c",
        "grey" => "#8a8f99", "gray" => "#8a8f99", "multi" => "#8b5cf6",
        _ => "#8b5cf6"
    };
}

<div class="wrap">
    <div class="crumb">
        <a asp-controller="Home" asp-action="Index">Home</a> /
        <span>@catName</span> /
        <b>@Model.Subcategory.Name</b>
    </div>

    <div class="toolbar">
        <h2>@Model.Subcategory.Name <span class="muted">· @Model.Products.Count product@(Model.Products.Count == 1 ? "" : "s")</span></h2>
        <div class="controls">
            <label class="sortbox">
                <span>Sort</span>
                <select onchange="location.href=this.value">
                    @foreach (var s in sorts)
                    {
                        <option value="@Url.Action("Subcategory", new { id = subId, sort = s.v, color = curColor })" selected="@((curSort ?? "name") == s.v ? "selected" : null)">@s.t</option>
                    }
                </select>
            </label>
            <a class="btn ghost" style="padding:9px 16px;font-size:13px" asp-controller="Home" asp-action="Index"><svg><use href="#back"/></svg> All categories</a>
        </div>
    </div>

    @if (colors.Any())
    {
        <div class="filters">
            <a class="fpill @(string.IsNullOrEmpty(curColor) ? "on" : "")" asp-controller="Products" asp-action="Subcategory" asp-route-id="@subId" asp-route-sort="@curSort">All colours</a>
            @foreach (var c in colors)
            {
                <a class="fpill @(string.Equals(curColor, c, StringComparison.OrdinalIgnoreCase) ? "on" : "")" asp-controller="Products" asp-action="Subcategory" asp-route-id="@subId" asp-route-sort="@curSort" asp-route-color="@c">
                    <span class="swatch" style="background:@ColorHex(c)"></span>@c
                </a>
            }
        </div>
    }

    @if (!Model.Products.Any())
    {
        <div class="empty">No products match this filter. <a asp-controller="Products" asp-action="Subcategory" asp-route-id="@subId">Clear filters</a></div>
    }
    else
    {
        <div class="prods" data-infinite>
            @{ var i = 0; }
            @foreach (var p in Model.Products)
            {
                var img = CatalogImages.For(catName, Model.Subcategory.Name, p.ProductNumber, i);
                i++;
                <a class="pcard" asp-controller="Products" asp-action="Details" asp-route-id="@p.ProductId">
                    <div class="pvis"><img src="@Url.Content(img)" alt="@p.Name" loading="lazy" /></div>
                    <div class="pbody">
                        <div class="pcode">@p.ProductNumber</div>
                        <h3 class="pname">@p.Name</h3>
                        <div class="pattrs">
                            @if (!string.IsNullOrWhiteSpace(p.Color))
                            {
                                <span class="attr"><span class="swatch" style="background:@ColorHex(p.Color)"></span>@p.Color</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(p.Size))
                            {
                                <span class="attr">Size @p.Size</span>
                            }
                        </div>
                        <div class="prow">
                            <div class="price num">$@p.ListPrice.ToString("N2")</div>
                            <span class="mini">Details <svg><use href="#arrow"/></svg></span>
                        </div>
                    </div>
                </a>
            }
        </div>
        <div id="scroll-sentinel" class="scroll-sentinel">Loading more…</div>
    }
</div>
